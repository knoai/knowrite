  authorStyles: [
    { name: '热血磅礴', description: '【玄幻】热血玄幻、霸气磅礴。世界观宏大、悬念重重、伏笔深远。人物名号响亮霸气，打斗场面要有"举世皆惊"、"震动天下"的宏大感，主角台词不屈霸气，同级无敌、逆天而行。' },
    { name: '少年逆袭', description: '【玄幻】退婚流/逆袭流鼻祖。少年热血、不屈不挠，修炼体系清晰，战斗节奏明快，爽点密集，情绪高昂。' },
    { name: '体系严谨', description: '【玄幻】设定严谨、战斗体系清晰、情感专一。擅长构建完整的世界规则与职业体系，主角坚韧正直，长线情感稳定。' },
    { name: '稳健策略', description: '【玄幻】番茄流代表。修炼体系自洽，节奏稳扎稳打，主角性格沉稳低调，重视家人与兄弟情，战斗讲究策略。' },
    { name: '深情宿命', description: '【仙侠】深情仙侠、宿命哲思。擅长写"我命如妖欲封天"的逆天感，文风深情而悲壮，人物执念深重，情节中常有宿命般的无奈与不屈，意境悠远，带有强烈的诗意和哲思。' },
    { name: '凡人', description: '【仙侠】凡人流、谨慎务实。主角出身平凡，靠谨慎、毅力和算计一步步崛起。文风沉稳务实，升级体系严谨，战斗讲究策略与底牌，弱小时隐忍，强大后一击必杀。' },
    { name: '唯美情殇', description: '【仙侠】诛仙式唯美玄幻。仙侠情缘与正魔对立交织，文笔优美抒情，重视情感悲剧与人物内心刻画，意境凄美。' },
    { name: '古典正统', description: '【仙侠】古典仙侠正统。文化底蕴深厚，重视诗词意境与传统道家文化，画面唯美，情感含蓄。' },
    { name: '门派情义', description: '【仙侠】正统仙侠。重视师徒情与门派归属感，文风稳健，战斗与情感并重。' },
    { name: '脑洞仙侠', description: '【仙侠】开创性仙侠。脑洞大开，设定新颖，文风轻松幽默，善于打破传统仙侠套路。' },
    { name: '团战热血', description: '【仙侠】热血团战型仙侠。重视兄弟情义与宗门争霸，战斗场面宏大，节奏明快，热血高燃。' },
    { name: '设定控', description: '【仙侠】设定严谨仙侠。世界观构建极其细致，修行体系有完整理论支撑，文风偏冷静理性。' },
    { name: '家族修仙', description: '【仙侠】以家族/宗门整体兴衰为核心，主角不仅是个人崛起，更要带领族人共享资源、共御外敌。重视血脉传承、灵地争夺、家族长老议事、后辈培养，强调"一人得道，鸡犬升天"的集体爽感与香火延续的使命感。' },
    { name: '程序员修仙', description: '【仙侠】用程序员的逻辑解构修仙世界。将功法视为代码、经脉视为架构、丹药视为性能优化，重视系统化思维与BUG修复式破局。文风理性中透着冷幽默，擅长用工程化语言描述玄学概念，爽点在于用理工科思维降维打击传统修仙者。' },
    { name: '现代农民修仙', description: '【仙侠/种田】以乡土田园为根基的现代修仙。主角通过灵泉、灵植、灵田改良农作物，带动全村致富。重视乡村人情、邻里关系、田园牧歌式生活，种田与修炼并重，爽点在于朴实的丰收喜悦与低调的乡土装逼。' },
    { name: '都市修仙', description: '【都市/仙侠】主角在现代都市中修炼，身怀仙法融入繁华都市。重视扮猪吃虎、医术/武道/风水在现代社会的降维应用，以及都市人情世故与修仙者超然心态的碰撞。爽点在于低调高手随手化解都市精英的困境。' },
    { name: '系统', description: '【泛题材】以系统面板为核心金手指。任务驱动剧情，数据化成长，完成目标即可获得奖励。重视明确的升级路径、即时反馈与确定性爽感，节奏极快，反转与打脸频繁。' },
    { name: '后宫轻松', description: '【都市】都市后宫/校园保镖流。轻松搞笑，女主众多，情节轻松愉快，适合青少年读者。' },
    { name: '暧昧温情', description: '【都市】都市情感/医生文。文笔幽默，人物鲜活，擅长写暧昧与温情并存的都市恋情。' },
