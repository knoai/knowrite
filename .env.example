# ============================================
# Multi-Agent 小说创作工作台 — 环境变量配置
# ============================================

# 服务端口
PORT=8000

# 默认 Provider（openai | ollama | lmstudio | yuanbao | doubao | kimi | qwen）
# API Provider（openai/ollama/lmstudio）直接本地直连
# Web Provider（yuanbao/doubao/kimi/qwen）需配合 PROXY_URL 使用
PROVIDER=openai

# 本地代理服务地址（Web Provider 转发目标）
# 如果你有自建的本地代理服务（如基于 Playwright 的浏览器自动化代理），
# multi-agent 会将 Web Provider 请求转发到此地址
PROXY_URL=http://localhost:9000

# 认证令牌（设置后所有 API 需要 Bearer Token 或 X-API-Key）
# 生产环境强烈建议设置
# AUTH_TOKEN=your-secret-token-here

# CORS 允许的来源（逗号分隔，留空则允许所有）
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 限流配置
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60

# 加密密钥（用于 AES-256-GCM 加密存储的 API Key 等敏感配置）
# 强烈建议设置，未设置时将回退到 base64 编码（安全性较低）
# ENCRYPTION_KEY=your-32-char-secret-key-here!!

# OpenAI 兼容 API Key（本地/远程厂商）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# 数据库配置（支持 SQLite / PostgreSQL）
# ============================================

# 数据库方言：sqlite（默认）| postgres
DB_DIALECT=sqlite

# SQLite 配置（当 DB_DIALECT=sqlite 时）
DB_STORAGE=./data/novel.db

# PostgreSQL 配置（当 DB_DIALECT=postgres 时）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=knowrite
# DB_USER=knowrite
# DB_PASSWORD=secret
# DB_POOL_MAX=10
# DB_POOL_MIN=0

# 数据库同步选项（仅开发用，生产环境勿启用）
# DB_SYNC_FORCE=true
# DB_SYNC_ALTER=true
